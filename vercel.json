{
  "version": 2,
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/.next",
  "installCommand": "npm install --legacy-peer-deps",
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase_service_role_key",
    "GRAPH_TENANT_ID": "@graph_tenant_id",
    "GRAPH_CLIENT_ID": "@graph_client_id",
    "GRAPH_CLIENT_SECRET": "@graph_client_secret",
    "PIPEDRIVE_TOKEN": "@pipedrive_token",
    "PIPEDRIVE_DOMAIN": "icoscapital",
    "USER_PIPEDRIVE_ID": "@user_pipedrive_id",
    "USER_INVESTMENT_MANAGER_OPTION_ID": "@user_investment_manager_option_id",
    "DEFAULT_PIPELINE_ID": "9",
    "DEFAULT_STAGE_ID": "141"
  },
  "functions": {
    "api/functions/**/*.ts": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "regions": ["iad1"],
  "framework": "nextjs"
}
